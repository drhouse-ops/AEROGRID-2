# GEMINI_API_KEY: Required for Gemini AI API calls on the backend.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime.
APP_URL=

# VITE_API_BASE_URL: Backend API base URL (empty for relative routes)
VITE_API_BASE_URL=

# VITE_GOOGLE_MAPS_API_KEY: Optional key for Google Maps Platform. Falling back to OpenStreetMap/Leaflet if not provided.
VITE_GOOGLE_MAPS_API_KEY=

# VITE_DEMO_MODE: Configures the mock persistence, seeded report, and forecast.
VITE_DEMO_MODE=true

# FIRMS_MAP_KEY: Optional NASA FIRMS API Map Key for active fire / thermal context. Sourced from firms.modaps.eosdis.nasa.gov.
FIRMS_MAP_KEY=

# GOOGLE_WEATHER_API_KEY: Server-side API key for Google Maps Platform Weather API.
# Used to retrieve real-time weather and atmospheric dispersion context for pollution persistence estimation.
# Never expose this key via any VITE_ public environment variables.
GOOGLE_WEATHER_API_KEY=

# DATA_GOV_IN_API_KEY: Government CPCB Air Quality API key from data.gov.in.
DATA_GOV_IN_API_KEY=
